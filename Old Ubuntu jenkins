#!/bin/bash
set -e

echo "===== Updating system ====="
sudo apt update -y
sudo apt upgrade -y

echo "===== Installing Java 21 ====="
sudo apt install -y openjdk-21-jdk wget

echo "===== Verifying Java ====="
java -version

echo "===== Creating Jenkins directory ====="
mkdir -p /opt/jenkins
cd /opt/jenkins

echo "===== Downloading Jenkins WAR ====="
wget -O jenkins.war https://get.jenkins.io/war-stable/latest/jenkins.war

echo "===== Creating Jenkins user ====="
sudo useradd -m -d /var/lib/jenkins -s /bin/bash jenkins || true

echo "===== Setting permissions ====="
sudo chown -R jenkins:jenkins /opt/jenkins
sudo mkdir -p /var/lib/jenkins
sudo chown -R jenkins:jenkins /var/lib/jenkins

echo "===== Creating systemd service ====="
sudo tee /etc/systemd/system/jenkins.service > /dev/null <<EOF
[Unit]
Description=Jenkins Server
After=network.target

[Service]
User=jenkins
WorkingDirectory=/opt/jenkins
ExecStart=/usr/bin/java -jar /opt/jenkins/jenkins.war --httpPort=8080
Restart=always

[Install]
WantedBy=multi-user.target
EOF

echo "===== Reloading systemd ====="
sudo systemctl daemon-reexec
sudo systemctl daemon-reload

echo "===== Starting Jenkins ====="
sudo systemctl start jenkins
sudo systemctl enable jenkins

echo "===== Jenkins Status ====="
sudo systemctl status jenkins --no-pager

echo "===== Getting Initial Admin Password ====="
sleep 10
sudo cat /var/lib/jenkins/secrets/initialAdminPassword || echo "Password not ready yet. Wait a few seconds and run manually."

echo "===== DONE ====="
echo "Access Jenkins at: http://<YOUR-EC2-PUBLIC-IP>:8080"

===========  RUN ==================================
chmod +x jenkins-setup.sh
./jenkins-setup.sh
